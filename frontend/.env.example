# Frontend env vars — copy this file to .env.local and fill in your values.
# All NEXT_PUBLIC_ vars are inlined into the client bundle at build time,
# so do not put anything here you wouldn't paste into a public gist.

# Chain RPC + id (local Anvil defaults shown)
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_CHAIN_ID=31337

# Contract addresses. These defaults are the Phase 7 Anvil deploy.
# On a fresh Anvil, after running `forge script script/Deploy.s.sol`, the
# addresses match these (account-0 nonce-deterministic CREATE). If you
# redeploy from a non-zero nonce, update these.
NEXT_PUBLIC_BRAWLERS_ADDRESS=0x322813Fd9A801c5507c9de605d63CEA4f2CE6c44
NEXT_PUBLIC_DUEL_ADDRESS=0xa85233C63b9Ee964Add6F2cffe00Fd84eb32338f
NEXT_PUBLIC_GRAVEYARD_ADDRESS=0x4A679253410272dd5232B3Ff7cF5dbB88f295319
NEXT_PUBLIC_BRAWL_ADDRESS=0x4ed7c70F96B99c776995fB64377f0d4aB3B0e1C1
NEXT_PUBLIC_MINTDROP_ADDRESS=0x09635F643e140090A9A8Dcd712eD6285858ceBef
NEXT_PUBLIC_USDT_ADDRESS=0x7a2088a1bFc9d81c55368AE168C2C02570cB814F

# Server-only — trusted signer key for Duel results.
# Must NOT have NEXT_PUBLIC_ prefix; consumed only by /api/run-duel.
# Local Anvil default = account 1 private key.
BRAWLERS_SIGNER_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
