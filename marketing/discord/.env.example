# Copy to .env (gitignored). Never commit a real token.

# Required. Discord bot token from https://discord.com/developers/applications
# (Bot tab → Reset Token). Discord auto-revokes tokens that ever appear in
# public chats/repos, so generate a fresh one if in doubt.
DISCORD_BOT_TOKEN=

# Required for the long-running bot (discord-bot service). The setup script
# also reads this if you'd rather not pass --guild on every invocation.
DISCORD_GUILD_ID=

# Optional — bot will hit this for duel history + token data. Defaults to
# the production Vercel URL.
# BRAWLERS_API_BASE=https://baseicbrawlers.com

# Optional — basescan tx URL prefix. Default is Base Sepolia. Switch to
# https://basescan.org/tx/ on mainnet day.
# BASESCAN_TX_BASE=https://sepolia.basescan.org/tx/

# Optional — duel watcher poll cadence in seconds. Default 60.
# DUEL_POLL_SEC=60

# Optional — leaderboard digest interval in hours. Default 24.
# LEADERBOARD_INTERVAL_HOURS=24

# Optional — set to true to fire one leaderboard post on bot startup
# (handy for testing). Default false.
# LEADERBOARD_ON_STARTUP=false

# Optional — set to a positive integer (e.g. 1) to replay the N most
# recent historical duels into #duels on bot startup. Useful for
# verifying the duel-watcher wiring without triggering a new duel.
# Default 0 (disabled).
# DUEL_BACKFILL_COUNT=0

# Optional — auto-repost the leaderboard whenever the top-N has materially
# shuffled. Throttled by the min-interval setting so a busy hour doesn't
# spam #leaderboard. Slash command /leaderboard ignores this throttle.
# LEADERBOARD_AUTO_UPDATE=false
# LEADERBOARD_MIN_INTERVAL_MIN=30
# LEADERBOARD_FP_DEPTH=5
