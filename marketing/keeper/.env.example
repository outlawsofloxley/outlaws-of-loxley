# BASEic Brawlers keeper config — fight-cost + resurrection-cost bots
# Copy to .env (gitignored) and fill in mainnet values after deploy.
#
# Both bots use the SAME private key + Chainlink feed. Only the target
# contract differs (router vs graveyard). Run as separate long-lived
# processes (Docker, pm2, systemd).

# ── Chain ─────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# ── Keeper EOA ────────────────────────────────────────────────────────
# Small ETH balance just for tx gas. NEVER use deployer/dev/signer.
# Same key for both keepers (cheaper, simpler). Both DuelRouter +
# Graveyard ownership must be transferred to this address post-deploy.
KEEPER_PRIVATE_KEY=

# ── Contracts (fill in post-deploy) ──────────────────────────────────
ROUTER_ADDRESS=
GRAVEYARD_ADDRESS=
BRAWL_ADDRESS=
BRAWL_PAIR_ADDRESS=

# ── Chainlink ETH/USD aggregator on Base mainnet ─────────────────────
# Verify before launch: https://docs.chain.link/data-feeds/price-feeds/addresses?network=base
CHAINLINK_ETH_USD=0x71041dDdAd3595F9CEd3DcCFBe3D1F4b0a16Bb70

# ── Polling cadence ──────────────────────────────────────────────────
POLL_SEC=300
DELTA_THRESHOLD=0.05

# ── Fight-cost bounds ─────────────────────────────────────────────────
# Lower floor is intentionally tiny — extends the $1 peg to any BRAWL
# price up to FDV in the trillions. The router's own MAX_FIGHT_COST_BRAWL
# constant (10,000 BRAWL) is the contract-side ceiling.
MIN_FIGHT_COST_BRAWL_WEI=1000000
MAX_FIGHT_COST_BRAWL_WEI=1000000000000000000000
MIN_FIGHT_COST_ETH_WEI=1000
MAX_FIGHT_COST_ETH_WEI=500000000000000000

# ── Resurrection-cost bounds ──────────────────────────────────────────
MIN_RESURRECT_WEI=1000000000000
MAX_RESURRECT_WEI=1000000000000000000

# ── Dry-run ──────────────────────────────────────────────────────────
# Set "true" for first deploy / debugging — computes + logs intent
# but never broadcasts.
DRY_RUN=false

# NOTE: the USD targets ($1/fight, $100/resurrect, $500/cap) are now stored
# ON-CHAIN in the router + graveyard contracts and editable from the dev
# dashboard via setFightCostUsdCents / setResurrectionCostUsdCents /
# setResurrectionCapUsdCents. The bots read those values each tick — no
# need to keep a TARGET_USD_CENTS env var in sync with the dashboard.
