# BASEic Brawlers keeper config (fight-cost + resurrection-cost bots)
# Copy to .env (gitignored) and fill in mainnet values after deploy.

# Chain
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# Keeper EOA — small ETH balance just for tx gas. NEVER use deployer/dev/signer.
# Same key for both keepers (cheaper, simpler). Both Duel + Graveyard must
# transfer ownership to this address post-deploy.
KEEPER_PRIVATE_KEY=

# Contracts (filled in post-deploy)
DUEL_ADDRESS=
GRAVEYARD_ADDRESS=
BRAWL_ADDRESS=
BRAWL_PAIR_ADDRESS=

# Dev / fee config — read once and threaded back through setFightEconomics
# unchanged. Keeper only adjusts the FIRST argument (fightCost).
DEV_TREASURY=
DEV_SHARE_BPS=1000

# Chainlink ETH/USD aggregator on Base mainnet.
# Verify before launch: https://docs.chain.link/data-feeds/price-feeds/addresses?network=base
CHAINLINK_ETH_USD=0x71041dDdAd3595F9CEd3DcCFBe3D1F4b0a16Bb70

# Fight-cost keeper tuning (target $1 / fight)
POLL_SEC=300
TARGET_USD_CENTS=100
DELTA_THRESHOLD=0.05
MIN_FIGHT_COST_WEI=1000000000000000000
MAX_FIGHT_COST_WEI=1000000000000000000000

# Resurrection-cost keeper tuning (target $100 base / revive)
# These vars override the fight defaults when running the resurrect keeper.
# In practice you'd run two processes with separate .env files (or override
# at the command line) — POLL_SEC etc are shared, TARGET_USD_CENTS differs.
# For the resurrect process:
#   TARGET_USD_CENTS=10000
#   MIN_RESURRECT_WEI=1000000000000000      (0.001 ETH)
#   MAX_RESURRECT_WEI=500000000000000000    (0.5 ETH = $2k cap)

# Set to "true" for first deploy / debugging — computes price + logs intent
# but never broadcasts.
DRY_RUN=false
