# BASEic Brawlers fight-cost keeper
# Copy to .env (gitignored) and fill in mainnet values after launch.

# Chain
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# Keeper EOA — small ETH balance just for tx gas. NEVER use deployer/dev/signer.
KEEPER_PRIVATE_KEY=

# Contracts (filled in post-deploy)
DUEL_ADDRESS=
BRAWL_ADDRESS=
BRAWL_PAIR_ADDRESS=

# Dev / fee config — read once and threaded back through setFightEconomics
# unchanged. Keeper only adjusts the FIRST argument (fightCost).
DEV_TREASURY=
DEV_SHARE_BPS=1000

# Chainlink ETH/USD aggregator on Base mainnet.
# Verify before launch: https://docs.chain.link/data-feeds/price-feeds/addresses?network=base
CHAINLINK_ETH_USD=0x71041dDdAd3595F9CEd3DcCFBe3D1F4b0a16Bb70

# Tuning (defaults shown; override only if you have a reason)
POLL_SEC=300
TARGET_USD_CENTS=100
DELTA_THRESHOLD=0.05
MIN_FIGHT_COST_WEI=1000000000000000000
MAX_FIGHT_COST_WEI=1000000000000000000000

# Set to "true" for first deploy / debugging — computes price + logs intent
# but never broadcasts.
DRY_RUN=false
