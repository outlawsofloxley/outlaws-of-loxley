# BASEic Brawlers TG userbot — host .env (NAS-only, mode 600, never committed)
# Lives at /mnt/.ix-apps/app_mounts/dockge/stacks/baseic-tg/.env on TrueNAS.

# ─── Telegram MTProto ───────────────────────────────────────────────
# Get from https://my.telegram.org → API development tools.
# One app per project; do NOT reuse smarties-tg's app credentials.
TG_API_ID=
TG_API_HASH=

# ─── LLM provider (DeepSeek default) ────────────────────────────────
# OpenAI-compatible API. Cheapest mainstream model. Substitute another
# OpenAI-compat provider by changing DEEPSEEK_BASE_URL + DEEPSEEK_MODEL.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ─── Userbot behaviour ──────────────────────────────────────────────
# Defaults to LISTENER_ONLY=true: incoming events are logged, no reply
# is ever sent. Watch the logs for at least an hour (ideally a day)
# before flipping to false.
USERBOT_LISTENER_ONLY=true

# Comma-separated group usernames (without the @). The userbot only
# auto-replies in these groups, and only to mentions or replies to its
# own messages. Public BB group: baseicbrawlers
USERBOT_AUTO_REPLY_GROUPS=baseicbrawlers

# DMs default off. Flip to true if you want auto-reply on DMs (after
# you've watched the DM logs and decided what kind of DMs come in —
# scammers, real fans, support questions, etc).
USERBOT_AUTO_REPLY_DMS=false

# Reply jitter (5-25s = roughly human typing latency)
USERBOT_REPLY_DELAY_MIN_SECONDS=5
USERBOT_REPLY_DELAY_MAX_SECONDS=25

# Hourly cap on outbound replies. Telegram's spam-detection threshold
# is around 30/hour for a fresh account. Start at 20, raise after a
# few quiet days if traffic justifies it.
USERBOT_HOURLY_REPLY_CAP=20
