# ─── Telegram bot tokens ──────────────────────────────────────────────
# Create three separate bots via @BotFather. Keep tokens out of git.
WELCOME_BOT_TOKEN=
RAID_BOT_TOKEN=
LEADERBOARD_BOT_TOKEN=

# ─── Telegram group / channel IDs ─────────────────────────────────────
# Get these by adding @username_to_id_bot or RawDataBot to the group.
# Negative integer = group/supergroup ID.
PUBLIC_GROUP_ID=
ANNOUNCE_CHANNEL_ID=

# ─── Brand strings (for /ca, /mint replies) ───────────────────────────
SITE_URL=https://baseicbrawlers.com
TG_PUBLIC=https://t.me/baseicbrawlers
TG_ANNOUNCE=https://t.me/baseicbrawlers_announce
X_HANDLE=https://x.com/BASEicBrawlers

# ─── Contracts (filled in once mainnet deploys) ───────────────────────
BRAWLERS_ADDRESS=
BRAWL_ADDRESS=
PAIR_ADDRESS=

# ─── DB ───────────────────────────────────────────────────────────────
DB_PATH=./bots-state.db
