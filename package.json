{
  "name": "brawlers",
  "version": "0.1.0",
  "description": "Brawlers - a pixel fighter NFT game. Phase 1: local scaffolding.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "hello": "tsx src/hello.ts",
    "game": "tsx src/cli/main.ts",
    "deploy:sepolia:dry": "node scripts/deploy.mjs --target sepolia --dry-run",
    "deploy:sepolia:preflight": "node scripts/deploy.mjs --target sepolia --phase preflight",
    "deploy:sepolia": "node scripts/deploy.mjs --target sepolia --yes",
    "deploy:mainnet:dry": "node scripts/deploy.mjs --target mainnet --dry-run",
    "deploy:mainnet:preflight": "node scripts/deploy.mjs --target mainnet --phase preflight",
    "deploy:mainnet": "node scripts/deploy.mjs --target mainnet"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@typescript-eslint/eslint-plugin": "7.16.1",
    "@typescript-eslint/parser": "7.16.1",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.3.3",
    "rimraf": "5.0.9",
    "tsx": "4.16.2",
    "typescript": "5.5.3",
    "vitest": "2.0.3"
  },
  "dependencies": {
    "dotenv": "16.4.5",
    "ethers": "6.16.0"
  }
}
