# ── Node / npm ───────────────────────────────────────────────
node_modules/
**/node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Logs ─────────────────────────────────────────────────────
*.log
*-trace.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Next.js / Turbopack ──────────────────────────────────────
.next/
out/
*.tsbuildinfo

# ── TypeScript / build output ────────────────────────────────
dist/
build/
/coverage/

# ── Foundry ──────────────────────────────────────────────────
broadcast/
cache/
foundry.lock

# ── Env (NEVER COMMIT; templates ARE ok) ─────────────────────
.env
.env.*
frontend/.env.local
frontend/.env.*
!.env.example
!frontend/.env.example

# ── Vercel ───────────────────────────────────────────────────
.vercel

# ── Local dev state (rolled per-session) ─────────────────────
data/brawlers.json
data/*.bak

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Claude Code session state (per-machine, never push) ──────
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/projects/

# ── Backups ─────────────────────────────────────────────────
*.bak

# ── Editor temp files ────────────────────────────────────────
*.swp
*.swo
*~

# ── Archives / session snapshots (keep local, don't push) ────
*.zip

# ── Certificates / private keys (belt and braces) ────────────
*.pem
*.key

.vercel
