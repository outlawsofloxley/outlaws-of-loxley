# Copy this file to `.env` and fill in real values.
# The real `.env` is gitignored and will never be pushed.
#
# For Phase 5 local development, the values below match Anvil's default
# test accounts. These keys are PUBLICLY KNOWN and only safe on local chains.
# NEVER reuse them on testnet or mainnet, generate fresh keys via
#   `cast wallet new` or `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`

# ── Game settings (Phases 1-3) ───────────────────────────────
BRAWLERS_DATA_DIR=./data
BRAWLERS_SEED=42

# ── Local Anvil chain (Phase 4+) ─────────────────────────────
BRAWLERS_RPC_URL=http://127.0.0.1:8545
BRAWLERS_CHAIN_ID=31337

# Contract addresses, filled in after `forge script Deploy` runs.
# For a fresh Anvil (nonce 0) with Account 0 as deployer, these are the
# deterministic CREATE addresses. If you redeploy or restart Anvil, they're
# still the same because Anvil seeds accounts the same way every time.
BRAWLERS_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
DUEL_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
GRAVEYARD_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0

# ── Wallet keys (LOCAL DEV ONLY) ─────────────────────────────
# PLAYER: the account that owns brawlers, mints, and submits duels.
# Default: Anvil account 0.
BRAWLERS_PLAYER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# SIGNER: the trusted signer whose signatures the Duel contract accepts.
# Default: Anvil account 1 (matches Deploy.s.sol default SIGNER_ADDRESS).
BRAWLERS_SIGNER_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# ── Discord webhook (Phase 6+) ───────────────────────────────
# Leave blank to disable.
DISCORD_WEBHOOK_URL=
